# Telegram YouTube Downloader bot configuration
# Copy this file to .env and fill in your bot token.

# === Required ===
# Get one from @BotFather on Telegram: /newbot
TELEGRAM_BOT_TOKEN=your_bot_token_here

# === Optional ===
# Upload size cap in MB. Plain Bot API allows 50 MB; a self-hosted local Bot
# API server allows up to 2000. Videos larger than this are rejected.
MAX_UPLOAD_MB=50

# Scratch directory for downloads (cleaned up after each request).
# Defaults to the system temp dir if unset.
DOWNLOAD_DIR=

# Restrict the bot to specific Telegram user IDs (comma-separated).
# Leave empty to allow anyone. Message @userinfobot to find your ID.
ALLOWED_USER_IDS=
