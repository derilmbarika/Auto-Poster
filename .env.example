# Auto Poster / Zernio configuration
# Copy this file to .env and paste your API key into ZERNIO_API_KEY.
# On first run, Claude will auto-fill the rest by calling
# GET https://zernio.com/api/v1/accounts with your key.

# === Only thing you need to fill in ===
ZERNIO_API_KEY=your_zernio_api_key_here

# === Auto-discovered on first run — leave blank if you want Claude to fill them ===
ZERNIO_ACCOUNT_INSTAGRAM=
ZERNIO_ACCOUNT_TIKTOK=
ZERNIO_ACCOUNT_YOUTUBE=
ZERNIO_ACCOUNT_FACEBOOK=

# === Auto-discovered, required only for --mode addToQueue ===
ZERNIO_PROFILE_ID=

# === Defaults — fine to leave as-is ===
ZERNIO_API_URL=https://zernio.com/api/v1
ZERNIO_TIMEZONE=America/Chicago
ZERNIO_QUEUE_ID=
